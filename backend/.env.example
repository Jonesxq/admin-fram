APP_NAME=Open Admin API
API_PREFIX=/api/v1
DATABASE_URL=mysql+pymysql://open_admin:open_admin_password@127.0.0.1:3306/open_admin
JWT_SECRET_KEY=change-me-in-local-env
JWT_EXPIRE_MINUTES=120
# Seed requires a strong admin password by default.
# For a local demo only, set INITIAL_ADMIN_PASSWORD=Admin123! and ALLOW_DEFAULT_ADMIN_PASSWORD=1.
INITIAL_ADMIN_PASSWORD=change-me-before-running-seed
ALLOW_DEFAULT_ADMIN_PASSWORD=0
