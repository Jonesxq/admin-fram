APP_NAME=Open Admin API
API_PREFIX=/api/v1
DATABASE_URL=mysql+pymysql://open_admin:open_admin_password@127.0.0.1:3306/open_admin
JWT_SECRET_KEY=change-me-in-local-env
JWT_EXPIRE_MINUTES=120
# Local demo seed account: admin / Admin123!
# This public default password is allowed only when both values below are set.
# For shared, staging, or production deployments, use a strong password and set ALLOW_DEFAULT_ADMIN_PASSWORD=0.
INITIAL_ADMIN_PASSWORD=Admin123!
ALLOW_DEFAULT_ADMIN_PASSWORD=1
